rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // User profiles
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if false;

      match /notifications/{notificationId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isSignedIn() &&
          (isOwner(userId) ||
            request.resource.data.actorUserId == request.auth.uid);
        allow update, delete: if isOwner(userId) || isAdmin();
      }
    }

    // Optional dedicated admins collection
    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Community forum posts
    match /forum_posts/{postId} {
      // Temporary open community mode:
      // all signed-in users can read, create, and reply/update.
      allow get, list: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.id == postId;

      allow update: if isAdmin() || (
        isSignedIn()
        && request.resource.data.userId == resource.data.userId
      );

      allow delete: if isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

service firebase.storage {
  match /b/{bucket}/o {
    
    // Profile Images logic
    match /profile_images/{userId}.jpg {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}

